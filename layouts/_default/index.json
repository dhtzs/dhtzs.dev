{{- $.Scratch.Add "index" slice -}}
{{- range site.RegularPages -}}
    {{- if and (not .Params.searchHidden) (ne .Layout `archives`) (ne .Layout `search`) }}
        {{- $title := .Title -}}
        {{- $content := .Plain -}}
        {{- $permalink := .Permalink -}}
        {{- $resources := slice -}}
        {{- range .Resources -}}
            {{- $resources = $resources | append .Permalink -}}
        {{- end -}}
        {{- $.Scratch.Add "index" (dict
            "title" $title
            "content" $content
            "permalink" $permalink
            "resources" $resources
        ) -}}
    {{- end }}
{{- end -}}
{{- $.Scratch.Get "index" | jsonify -}}
